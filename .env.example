# Telegram
TELEGRAM_BOT_TOKEN=123456:your-bot-token

# Google Sheets
GOOGLE_SHEET_ID=your_spreadsheet_id

# Option A: legacy Tiubot-compatible service-account fields
GOOGLE_SERVICE_ACCOUNT_EMAIL=money-bot@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Option B: full service-account JSON through env; configure google.credentialsJSONEnv if used.
GOOGLE_CREDENTIALS_JSON='{"type":"service_account","client_email":"...","private_key":"..."}'

# AI parsing is always enabled.
# Default config uses local LM Studio at http://localhost:1234/v1 and does not require a key.
# If using OpenRouter instead, set ai.provider=openrouter and provide this key.
OPENROUTER_API_KEY=sk-or-your-key
